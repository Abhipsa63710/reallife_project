   "source": [
    "# Call Center Analytics \n",
    "import numpy as np \n",
    "calls = np.random.randint(100,700,30) \n",
    "print(\"Average Calls:\",calls.mean()) \n",
    "print(\"Highest Calls:\",calls.max()) \n",
    "print(\"Lowest Calls:\",calls.min()) \n",
    "print(\"Busy Days\") \n",
    "print(calls[calls>500]) "
   ]

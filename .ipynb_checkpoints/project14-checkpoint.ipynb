   "source": [
    "# Online Shopping Return Analytics \n",
    "import numpy as np \n",
    "returns = np.random.choice([0,1],500,p=[0.88,0.12]) \n",
    "print(\"Total Orders:\",returns.size) \n",
    "print(\"Returned Orders:\",returns.sum()) \n",
    "print(\"Return Percentage\") \n",
    "print((returns.mean())*100,\"%\") "
   ]

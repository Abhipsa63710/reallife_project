   "source": [
    "#Stock Market Analytics \n",
    "import numpy as np \n",
    "price = np.random.randint(900,1200,250) \n",
    "daily_change = np.diff(price) \n",
    "print(\"Maximum Gain:\",daily_change.max()) \n",
    "print(\"Maximum Loss:\",daily_change.min()) \n",
    "print(\"Average Change:\",daily_change.mean()) "
   ]

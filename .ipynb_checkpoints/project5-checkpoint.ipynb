    "#Banking Transaction Analytics \n",
    "import numpy as np \n",
    "transactions = np.random.randint(100,100000,1000) \n",
    "print(\"Average Transaction:\",transactions.mean()) \n",
    "print(\"Largest Transaction:\",transactions.max()) \n",
    "print(\"Transactions Above 50,000\") \n",
    "print(transactions[transactions>50000]) "

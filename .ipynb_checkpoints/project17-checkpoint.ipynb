    "#Telecom Customer Usage Analytics \n",
    "import numpy as np \n",
    "usage = np.random.randint(1,40,1000) \n",
    "print(\"Average Data Usage:\",usage.mean(),\"GB\") \n",
    "print(\"Heavy Users:\",np.sum(usage>30)) \n",
    "print(\"Light Users:\",np.sum(usage<5)) "

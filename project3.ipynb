    "#Uber Ride Analytics\n",
    "import numpy as np \n",
    "np.random.seed(10) \n",
    "rides = np.random.randint(50,500,100) \n",
    "print(\"Average Daily Rides:\",rides.mean()) \n",
    "print(\"Peak Ride Count:\",rides.max()) \n",
    "print(\"Minimum Ride Count:\",rides.min()) \n",
    "print(\"High Demand Days\") \n",
    "print(rides[rides>400]) "
   ]

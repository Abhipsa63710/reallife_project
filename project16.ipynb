   "source": [
    "# Restaurant Order Analytics \n",
    "import numpy as np \n",
    "orders = np.random.randint(50,400,30) \n",
    "print(\"Average Orders:\",orders.mean()) \n",
    "print(\"Highest Orders:\",orders.max()) \n",
    "print(\"Busy Days:\",np.where(orders>300)[0]+1) "
   ]

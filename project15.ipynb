    "# Social Media Analytics \n",
    "import numpy as np \n",
    "likes = np.random.randint(100,10000,200)\n",
    "print(\"Average Likes:\",likes.mean()) \n",
    "print(\"Highest Likes:\",likes.max()) \n",
    "print(\"Viral Posts\") \n",
    "print(np.sum(likes>8000)) "

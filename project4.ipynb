    "#Employee Salary Analytics\n",
    "import numpy as np \n",
    "salary = np.random.randint(25000,150000,500) \n",
    "print(\"Average Salary:\",salary.mean()) \n",
    "print(\"Highest Salary:\",salary.max()) \n",
    "print(\"Lowest Salary:\",salary.min()) \n",
    "print(\"Employees earning above 1 Lakh\") \n",
    "print(len(salary[salary>100000])) "
   ]

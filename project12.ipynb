   "source": [
    "# Cricket Match Analytics \n",
    "import numpy as np \n",
    "runs = np.random.randint(0,151,50) \n",
    "print(\"Average Score:\",runs.mean()) \n",
    "print(\"Highest Score:\",runs.max()) \n",
    "print(\"Centuries:\",np.sum(runs>=100))\n",
    "print(\"Half Centuries:\",np.sum((runs>=50)&(runs<100))) "
   ]

   "source": [
    "# Movie Rating Analytics \n",
    "import numpy as np \n",
    "ratings = np.random.uniform(1,5,500) \n",
    "print(\"Average Rating:\",ratings.mean()) \n",
    "print(\"Highest Rating:\",ratings.max()) \n",
    "print(\"Movies Rated Above 4\") \n",
    "print(np.sum(ratings>4)) "
   ]

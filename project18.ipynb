    "# Manufacturing Defect Analytics \n",
    "import numpy as np \n",
    "defects = np.random.randint(0,15,100) \n",
    "print(\"Average Defects:\",defects.mean()) \n",
    "print(\"Maximum Defects:\",defects.max()) \n",
    "print(\"Days With Zero Defects:\",np.sum(defects==0)) "
   ]

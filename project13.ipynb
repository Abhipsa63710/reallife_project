    "# Flight Delay Analytics \n",
    "import numpy as np \n",
    "delay = np.random.randint(0,180,500) \n",
    "print(\"Average Delay:\",delay.mean()) \n",
    "print(\"Maximum Delay:\",delay.max()) \n",
    "print(\"Flights Delayed > 60 Minutes\") \n",
    "print(np.sum(delay>60)) "

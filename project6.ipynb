    "#Electricity Consumption Analytics \n",
    "import numpy as np \n",
    "units = np.random.randint(100,700,365) \n",
    "print(\"Yearly Units:\",units.sum()) \n",
    "print(\"Monthly Average:\",units.mean()) \n",
    "print(\"Maximum Consumption:\",units.max())\n",
    "print(\"Minimum Consumption:\",units.min()) "
